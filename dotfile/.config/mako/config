include=~/.config/mako/mako-colors

# Global Configuration Options
max-history=5
sort=-time

# Appearance
font=monospace 10
width=300
height=100
margin=10
padding=10
border-size=2
border-radius=0
progress-color=over #16a085

# Behavior
default-timeout=3000
ignore-timeout=0
icons=1
max-icon-size=64

# Binding Options
on-button-left=invoke-default-action
on-button-middle=none
on-button-right=dismiss
on-touch=dismiss

# Style Overrides (Example: Critical notifications)
[urgency=high]
border-color=#bf616a
default-timeout=0

